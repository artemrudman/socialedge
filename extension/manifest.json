{
  "manifest_version": 3,
  "name": "SocialEdge",
  "version": "2.1.0",
  "description": "Track and grow your LinkedIn Social Selling Score — automatically, every day.",

  "permissions": [
    "cookies",
    "webRequest",
    "storage",
    "alarms",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_icon": "icons/icon.svg",
    "default_title": "SocialEdge — Your Selling Score"
  },

  "side_panel": {
    "default_path": "popup.html"
  },

  "icons": {
    "16":  "icons/icon.svg",
    "48":  "icons/icon.svg",
    "128": "icons/icon.svg"
  },

  "web_accessible_resources": [
    {
      "resources": ["Info Plan.pdf"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content_main.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
