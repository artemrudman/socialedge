{
  "manifest_version": 3,
  "name": "SocialEdge",
  "version": "2.1.4",
  "description": "Track and grow your LinkedIn Social Selling Score — automatically, every day.",

  "permissions": [
    "cookies",
    "webRequest",
    "storage",
    "alarms",
    "scripting",
    "tabs",
    "sidePanel",
    "identity",
    "notifications"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*"
  ],

  "oauth2": {
    "client_id": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "SocialEdge — Your Selling Score"
  },

  "side_panel": {
    "default_path": "popup.html"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["Info Plan.pdf"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content_main.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
