{
  "manifest_version": 3,
  "name": "SocialEdge",
  "version": "2.0.0",
  "description": "Track and grow your LinkedIn Social Selling Score — automatically, every day.",

  "permissions": [
    "cookies",
    "webRequest",
    "storage",
    "alarms",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg",
    "default_title": "SocialEdge — Your Selling Score"
  },

  "icons": {
    "16":  "icons/icon.svg",
    "48":  "icons/icon.svg",
    "128": "icons/icon.svg"
  },

  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content_main.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
