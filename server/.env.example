# ── SocialEdge Server Environment ──────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Server
PORT=3000

# JWT secret — generate a random 64-char string
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Google OAuth
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (type: Web application)
# 3. Add "https://<extension-id>.chromiumapp.org" to Authorized redirect URIs
# 4. Paste Client ID and Secret here
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
